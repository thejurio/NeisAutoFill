<Window x:Class="NeisAutoFill.App.GeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="교과학습발달상황 생성" Icon="app.ico" Height="740" Width="1000" MinWidth="780" MinHeight="520"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="20" Height="20" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="교과학습발달상황 생성" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="Max_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="Min_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- 툴바 (1줄: 생성 / 2줄: 자료·입력) -->
            <Border Grid.Row="1" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                <StackPanel Margin="14,10">
                    <!-- 1줄: 생성 -->
                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <!-- 전담: 교과 + 학년반 선택 (창 안에서 조합을 바꿔 생성·입력) -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsSubjectMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="교과" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,5,0"/>
                                <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding GenSubjects}" SelectedItem="{Binding GenSubject}" MinWidth="96" Margin="0,0,10,0"/>
                                <TextBlock Text="학년·반" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,5,0"/>
                                <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding GenClasses}" SelectedItem="{Binding GenClass}" MinWidth="72" Margin="0,0,10,0"/>
                            </StackPanel>
                            <!-- 담임: 과목 선택 -->
                            <TextBlock Text="과목" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,5,0"
                                       Visibility="{Binding IsSubjectMode, Converter={StaticResource TrueToCollapsed}}"/>
                            <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding SubjectNames}" SelectedItem="{Binding SelectedSubject}" MinWidth="120" Margin="0,0,10,0"
                                      Visibility="{Binding IsSubjectMode, Converter={StaticResource TrueToCollapsed}}"/>
                            <CheckBox Content="전체선택" IsChecked="{Binding SelectAll}" VerticalAlignment="Center" FontSize="12" Margin="0,0,14,0"/>
                            <TextBlock Text="이 과목 글자수" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,5,0"/>
                            <TextBox Text="{Binding SubjectTargetChars, UpdateSourceTrigger=LostFocus}" Width="52" VerticalContentAlignment="Center"
                                     ToolTip="이 과목만 목표 글자 수를 다르게 지정 (비우면 설정의 전역 글자 수 사용)"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButton}" Content="⛔ 중지" Command="{Binding CancelGenerationCommand}" Margin="0,0,8,0"
                                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="🌐 전과목 생성" Command="{Binding GenerateSubjectsCommand}" Margin="0,0,4,0"
                                    Visibility="{Binding ShowBatchGenerate, Converter={StaticResource BoolToVis}}"
                                    ToolTip="여러 과목을 한 번에 백그라운드로 생성합니다"/>
                            <Button Style="{StaticResource AccentGhostButton}" Content="{Binding GenerateOneLabel}" Command="{Binding GenerateAllCommand}" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource AccentGhostButton}" Content="☑ 선택만 생성" Command="{Binding GenerateSelectedCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <!-- 2줄: 자료 관리 · 나이스 입력 -->
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButton}" Content="💾 저장" Command="{Binding SaveCommand}" Margin="0,0,4,0"
                                    ToolTip="작업공간 서술문.xlsx 에 저장합니다 (문서\NeisAutoFill)"/>
                            <Button Style="{StaticResource GhostButton}" Content="📤 내보내기" Command="{Binding ExportCommand}" Margin="0,0,4,0"
                                    ToolTip="원하는 위치에 엑셀 파일로 내보냅니다 (과목별 시트)"/>
                            <Button Style="{StaticResource GhostButton}" Content="📋 전과목 한장 저장" Command="{Binding ExportMatrixCommand}" Margin="0,0,4,0"
                                    ToolTip="전과목 서술문을 한 시트에 매트릭스로 저장합니다 (학생 행 × 과목 열)"/>
                            <Button Style="{StaticResource GhostButton}" Content="📂 불러오기" Command="{Binding ImportCommand}" Margin="0,0,10,0"
                                    ToolTip="엑셀에서 수정한 서술문을 되가져옵니다 (과목별 시트: 번호|이름|서술문)"/>
                            <Border Width="1" Background="{StaticResource Line}" Margin="0,3,10,3"/>
                            <Button Style="{StaticResource DangerGhostButton}" Content="🗑 삭제 ▾" Click="DeleteMenu_Click">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="선택 학생 삭제" Command="{Binding DeleteSelectedCommand}"/>
                                        <MenuItem Header="현재 과목 삭제" Command="{Binding DeleteSubjectCommand}"/>
                                        <MenuItem Header="전체 과목 삭제" Command="{Binding DeleteAllSubjectsCommand}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="■" Padding="9,5" Command="{Binding CancelUploadCommand}" Margin="6,0,0,0"
                                Visibility="{Binding IsUploading, Converter={StaticResource BoolToVis}}"
                                ToolTip="진행 중인 나이스 서술문 입력을 중지합니다 (전체반/전과목 배치도 그 자리에서 중단)"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="{Binding UploadAllLabel}" Command="{Binding UploadAllCommand}"
                                ToolTip="여러 대상의 서술문을 순서대로 나이스에 입력합니다. 각 대상 검증 통과 시 자동 [저장] 후 다음으로 넘어갑니다."/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource AccentGhostButton}" Content="{Binding UploadOneLabel}" Command="{Binding UploadCommand}" Margin="0,0,6,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 상태 + 백그라운드 생성 진행 -->
            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="14,7">
                <StackPanel>
                    <TextBlock Text="{Binding PlanStatus}" Foreground="{StaticResource Sub}" FontSize="11.5"/>
                    <DockPanel Margin="0,6,0,0" Visibility="{Binding QueueStatus, Converter={StaticResource StringToVis}}">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding QueueStatus}" Foreground="{StaticResource Neis}"
                                   FontSize="11.5" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ProgressBar Height="5" Minimum="0" Maximum="{Binding QueueTotal}" Value="{Binding QueueProgress, Mode=OneWay}"
                                     Background="{StaticResource Panel}" Foreground="{StaticResource Neis}" BorderThickness="0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <!-- 서술문 품질 점검 (복붙 의심) -->
                    <TextBlock Text="{Binding QualityNote}" Foreground="#B45309" FontSize="11.5" FontWeight="SemiBold"
                               TextWrapping="Wrap" Margin="0,6,0,0"
                               Visibility="{Binding QualityNote, Converter={StaticResource StringToVis}}"/>
                </StackPanel>
            </Border>

            <!-- 설정은 메인 화면 [⚙ 설정]으로 통합 (AI 분량·톤·바이트 제한) -->

            <!-- 학생 목록 -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="14,10">
                <ItemsControl ItemsSource="{Binding Students}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StudentGenItem}">
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10"
                                    Padding="12" Margin="0,0,0,8" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="생성"
                                                Command="{Binding GenerateCommand}" Padding="14,5"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding UploadState}" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#0F766E" FontSize="12"/>
                                        <!-- 바이트 수 (제한 초과 시 빨강) -->
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ByteInfo}" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OverLimit}" Value="True">
                                                            <Setter Property="Foreground" Value="#C0392B"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- 복붙 의심 — 경고 겸 원클릭 재생성 -->
                                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="⚠ 다르게 다시 생성"
                                                Command="{Binding RegenerateDistinctCommand}" Padding="8,3" Margin="0,0,10,0" FontSize="11"
                                                ToolTip="다른 학생과 서술문이 매우 유사합니다 — 표현을 달리해 이 학생만 다시 생성합니다"
                                                Visibility="{Binding IsSimilarSuspect, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel>
                                            <TextBlock FontSize="13">
                                                <Run Text="{Binding No, Mode=OneWay}" Foreground="{StaticResource Sub}"/><Run Text="번 " Foreground="{StaticResource Sub}"/>
                                                <Run Text="{Binding Name, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                                <Run Text="    "/>
                                                <Run Text="{Binding DomainsSummary, Mode=OneWay}" Foreground="#475569"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding NoteSummary}" Foreground="{StaticResource Sub}" FontSize="11.5" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBox Grid.Row="1" Text="{Binding Result, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="52" MaxHeight="220"
                                             Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                             Padding="8,6" FontSize="12.5" VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
