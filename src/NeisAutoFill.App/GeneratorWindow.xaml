<Window x:Class="NeisAutoFill.App.GeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="교과학습발달상황 생성" Icon="app.ico" Height="740" Width="1000" MinWidth="780" MinHeight="520"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="20" Height="20" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="교과학습발달상황 생성" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="Max_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="Min_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- 툴바 -->
            <Border Grid.Row="1" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                <WrapPanel Margin="14,10">
                    <TextBlock Text="과목" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,5,0"/>
                    <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding SubjectNames}" SelectedItem="{Binding SelectedSubject}" MinWidth="110" Margin="0,0,12,0"/>
                    <CheckBox Content="전체선택" IsChecked="{Binding SelectAll}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="🚀 전체 생성" Command="{Binding GenerateAllCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource AccentGhostButton}" Content="☑ 선택만 생성" Command="{Binding GenerateSelectedCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource GhostButton}" Content="🗑 전체 삭제" Command="{Binding DeleteAllCommand}" Margin="0,0,4,0"
                            ToolTip="현재 과목의 생성된 서술문을 모두 지웁니다"/>
                    <Button Style="{StaticResource GhostButton}" Content="🗑 선택 삭제" Command="{Binding DeleteSelectedCommand}" Margin="0,0,14,0"
                            ToolTip="체크한 학생의 서술문만 지웁니다"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="▶ 나이스에 입력" Command="{Binding UploadCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource GhostButton}" Content="💾 엑셀 저장" Command="{Binding ExportCommand}"
                            ToolTip="모든 과목의 생성된 서술문을 과목별 시트로 저장합니다"/>
                </WrapPanel>
            </Border>

            <!-- 상태 -->
            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="14,7">
                <TextBlock Text="{Binding PlanStatus}" Foreground="{StaticResource Sub}" FontSize="11.5"/>
            </Border>

            <!-- 설정 -->
            <Expander Grid.Row="3" Header="⚙ 설정" Margin="14,6,14,0" FontSize="12" Foreground="{StaticResource Sub}">
                <DockPanel Margin="4,8">
                    <TextBlock Text="바이트 제한" Width="80" VerticalAlignment="Center" FontSize="12"/>
                    <TextBlock DockPanel.Dock="Right" Text=" (나이스 입력 전 UTF-8 바이트 사전검사, 0 = 검사 안 함)"
                               VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                    <TextBox Text="{Binding MaxNarrativeBytes, UpdateSourceTrigger=LostFocus}" Width="80" Height="28" VerticalContentAlignment="Center"/>
                </DockPanel>
            </Expander>

            <!-- 학생 목록 -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="14,10">
                <ItemsControl ItemsSource="{Binding Students}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StudentGenItem}">
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10"
                                    Padding="12" Margin="0,0,0,8" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="생성"
                                                Command="{Binding GenerateCommand}" Padding="14,5"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding UploadState}" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#0F766E" FontSize="12"/>
                                        <StackPanel>
                                            <TextBlock FontSize="13">
                                                <Run Text="{Binding No, Mode=OneWay}" Foreground="{StaticResource Sub}"/><Run Text="번 " Foreground="{StaticResource Sub}"/>
                                                <Run Text="{Binding Name, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                                <Run Text="    "/>
                                                <Run Text="{Binding DomainsSummary, Mode=OneWay}" Foreground="#475569"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding NoteSummary}" Foreground="{StaticResource Sub}" FontSize="11.5" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBox Grid.Row="1" Text="{Binding Result, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="52" MaxHeight="220"
                                             Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                             Padding="8,6" FontSize="12.5" VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
