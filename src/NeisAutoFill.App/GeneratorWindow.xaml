<Window x:Class="NeisAutoFill.App.GeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        Title="AI 교과 서술문 생성기" Icon="app.ico" Height="720" Width="980" MinWidth="760" MinHeight="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1행: 과목 선택 + 생성 + 나이스 입력 (자료는 메인 창에서 로드된 것을 자동 사용) -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="과목:" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox ItemsSource="{Binding SubjectNames}" SelectedItem="{Binding SelectedSubject}"
                      MinWidth="120" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <CheckBox Content="전체선택" IsChecked="{Binding SelectAll}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="🚀 전체 생성" Command="{Binding GenerateAllCommand}" Padding="10,6" Margin="0,0,4,0"/>
            <Button Content="☑ 선택만 생성" Command="{Binding GenerateSelectedCommand}" Padding="10,6" Margin="0,0,16,0"/>
            <Button Content="▶ 나이스에 서술문 입력 (저장은 수동)" Command="{Binding UploadCommand}" Padding="10,6" Margin="0,0,6,0"/>
            <Button Content="💾 엑셀로 저장" Command="{Binding ExportCommand}" Padding="10,6"
                    ToolTip="모든 과목의 생성된 서술문을 과목별 시트로 저장합니다"/>
        </WrapPanel>

        <TextBlock Grid.Row="1" Text="{Binding PlanStatus}" Foreground="#64748B" Margin="0,0,0,6"/>

        <!-- 설정 -->
        <Expander Grid.Row="2" Header="⚙ 설정" Margin="0,0,0,6">
            <StackPanel Margin="8">
                <DockPanel>
                    <TextBlock Text="바이트 제한:" Width="90" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" Text=" (나이스 입력 전 UTF-8 바이트 사전검사, 0 = 검사 안 함)"
                               VerticalAlignment="Center" Foreground="#64748B" FontSize="11"/>
                    <TextBox Text="{Binding MaxNarrativeBytes, UpdateSourceTrigger=LostFocus}" Width="80"/>
                </DockPanel>
            </StackPanel>
        </Expander>

        <!-- 학생 목록 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Students}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:StudentGenItem}">
                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6"
                                Padding="10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button DockPanel.Dock="Right" Content="생성"
                                            Command="{Binding GenerateCommand}" Padding="12,4"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UploadState}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                               FontWeight="Bold" Foreground="#0F766E"/>
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding No, Mode=OneWay}"/><Run Text="번 "/>
                                            <Run Text="{Binding Name, Mode=OneWay}" FontWeight="Bold"/>
                                            <Run Text="   "/>
                                            <Run Text="{Binding DomainsSummary, Mode=OneWay}" Foreground="#334155"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding NoteSummary}" Foreground="#64748B" FontSize="12"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBox Grid.Row="1" Text="{Binding Result, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                                         Background="#F8FAFC" BorderBrush="#E2E8F0"
                                         VerticalScrollBarVisibility="Auto" MaxHeight="200"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
