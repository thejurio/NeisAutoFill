<Window x:Class="NeisAutoFill.App.PlanEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="명단·평가계획 편집" Height="620" Width="1080" MinWidth="900" MinHeight="480"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
      <Grid>
        <DockPanel>
            <!-- 타이틀바 -->
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="명단·평가계획 편집" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Cancel_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- 하단 버튼 -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="11.5" Foreground="{StaticResource Sub}"
                               Text="저장하면 작업공간의 평가계획서 엑셀 파일에 기록되고 즉시 적용됩니다."/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="취소" IsCancel="True" Padding="18,7"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="저장 후 적용" Click="Save_Click" Margin="0,0,6,0" Padding="18,7"/>
                </DockPanel>
            </Border>

            <Grid Margin="16,12,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="285"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== 좌: 학생 명단 ===== -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="학생 명단" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}" Margin="0,0,0,6"/>
                    <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="엑셀에서 번호·이름 열을 복사한 뒤 [붙여넣기]를 누르면 명단 전체가 한 번에 입력됩니다."/>
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="False">
                        <Button DockPanel.Dock="Left" Style="{StaticResource GhostButton}" Content="＋ 행" Command="{Binding AddRosterRowCommand}" Margin="0,0,4,0"/>
                        <Button DockPanel.Dock="Left" Style="{StaticResource GhostButton}" Content="－ 행" Command="{Binding RemoveRosterRowCommand}" Margin="0,0,4,0"/>
                        <Button DockPanel.Dock="Left" Style="{StaticResource AccentGhostButton}" Content="📋 붙여넣기" Click="PasteRoster_Click"
                                ToolTip="엑셀에서 번호·이름 열을 복사한 뒤 누르면 명단 전체가 한 번에 입력됩니다 (기존 명단은 교체)"/>
                        <Button DockPanel.Dock="Right" Style="{StaticResource DangerGhostButton}" Content="🗑 명단 비우기" Click="ClearRoster_Click"
                                ToolTip="학생 명단을 모두 지웁니다"/>
                    </DockPanel>
                    <DataGrid x:Name="RosterGrid" ItemsSource="{Binding Roster}" SelectedItem="{Binding SelectedRosterRow}"
                              Style="{StaticResource CleanGrid}" ColumnHeaderStyle="{StaticResource CleanGridHeader}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserSortColumns="False" CanUserReorderColumns="False" RowHeight="30"
                              BorderBrush="{StaticResource Line}" BorderThickness="1"
                              PreviewKeyDown="RosterGrid_PreviewKeyDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="번호" Binding="{Binding No, UpdateSourceTrigger=PropertyChanged}" Width="56"/>
                            <DataGridTextColumn Header="이름" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border Grid.Column="1" Width="1" Background="{StaticResource Line}" HorizontalAlignment="Center"/>

                <!-- ===== 우: 과목별 평가계획 ===== -->
                <DockPanel Grid.Column="2">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource AccentGhostButton}" Content="📄 평가계획 불러오기" Command="{Binding ImportPlanCommand}"
                                    ToolTip="이지에듀·스쿨마스터 등 평가계획서(PDF/HWP/HWPX)를 넣으면 AI가 인식해 표에 채웁니다"
                                    Margin="0,0,10,0"/>
                            <Button Style="{StaticResource GhostButton}" Content="＋ 과목" Command="{Binding AddSubjectCommand}" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource DangerGhostButton}" Content="🗑 삭제" Click="PlanDeleteMenu_Click">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="이 과목 삭제" Command="{Binding RemoveSubjectCommand}"/>
                                        <MenuItem Header="전체 평가계획 비우기" Click="ClearAllPlans_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="과목" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Sub}" Margin="0,0,6,0"/>
                            <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Subjects}" SelectedItem="{Binding SelectedSubject}"
                                      DisplayMemberPath="Name" MinWidth="130" Margin="0,0,10,0"/>
                            <TextBlock Text="과목명" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Sub}" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SelectedSubject.Name, UpdateSourceTrigger=PropertyChanged}" Width="130" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,0,0,4">
                        <Run Text="행 = 평가영역. 마지막 빈 행에 입력하면 영역이 추가됩니다. 엑셀 표를 복사해 셀에서 Ctrl+V 로 붙여넣을 수 있습니다. 등급 열:"/>
                        <Run Text="{Binding ScaleSummary, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding ImportStatus}" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource Neis}" TextWrapping="Wrap" Margin="0,0,0,8"
                               Visibility="{Binding ImportStatus, Converter={StaticResource StringToVis}}"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource GhostButton}" Content="＋ 영역 행" Click="AddPlanRow_Click" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource GhostButton}" Content="－ 선택 행 삭제" Click="RemovePlanRow_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="PlanGrid" ItemsSource="{Binding SelectedSubject.GridView}"
                              Style="{StaticResource CleanGrid}" ColumnHeaderStyle="{StaticResource CleanGridHeader}"
                              AutoGenerateColumns="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserSortColumns="False" CanUserReorderColumns="False"
                              SelectionUnit="CellOrRowHeader" SelectionMode="Extended" ClipboardCopyMode="ExcludeHeader"
                              BorderBrush="{StaticResource Line}" BorderThickness="1"
                              AutoGeneratingColumn="PlanGrid_AutoGeneratingColumn"
                              PreviewKeyDown="PlanGrid_PreviewKeyDown">
                        <DataGrid.Resources>
                            <Style TargetType="TextBlock" x:Key="WrapCell">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </DockPanel>

        <!-- AI 분석 중 오버레이 — 화면 전체를 덮어 처리 중임을 직관적으로 표시 -->
        <Border Background="#B3FFFFFF" Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}">
            <Border Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="1.5" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="34,26" MaxWidth="440">
                <StackPanel>
                    <TextBlock Text="🤖" FontSize="34" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="AI 가 평가계획서를 읽고 있어요" FontWeight="Bold" FontSize="14.5"
                               Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ImportStatus}" FontSize="11.5" Foreground="{StaticResource Sub}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,14"/>
                    <ProgressBar IsIndeterminate="True" Height="6" Width="260"
                                 Background="{StaticResource Panel}" Foreground="{StaticResource Neis}" BorderThickness="0"/>
                    <TextBlock Text="문서 분량에 따라 수십 초가 걸릴 수 있습니다" FontSize="10.5" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Border>
      </Grid>
    </Border>
</Window>
