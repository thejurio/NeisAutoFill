<Window x:Class="NeisAutoFill.App.PlanPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding Title}" SizeToContent="Height" MaxHeight="720" Width="600" MinWidth="480"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <!-- 제목 -->
            <Border DockPanel.Dock="Top" Height="36" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="14,0" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource Ink}"/>
            </Border>

            <!-- 하단 버튼 -->
            <Border DockPanel.Dock="Bottom" Padding="14,10" Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="취소" Click="Cancel_Click" Padding="16,6"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="불러오기" Click="Ok_Click" Padding="16,6" Margin="0,0,6,0"/>
                    <CheckBox x:Name="SelectAll" DockPanel.Dock="Left" Content="전체 선택" VerticalAlignment="Center"
                              IsChecked="True" Click="SelectAll_Click" FontSize="12"/>
                </DockPanel>
            </Border>

            <!-- 안내 -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding Hint}" Margin="14,10,14,6" FontSize="11.5"
                       Foreground="{StaticResource Sub}" TextWrapping="Wrap"/>

            <!-- 헤더 + 목록을 한 Grid 로 묶고, 두 단 사이에 진한 세로선을 관통시킨다 -->
            <Grid Margin="8,0,8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 열 제목 (과목 / 학년) — 두 단 각각에 맞춰 정렬 -->
                <Border Grid.Row="0" Padding="0,2,0,5" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                    <UniformGrid Columns="2">
                        <DockPanel Margin="4,0" LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right" Text="학년" Width="78" TextAlignment="Center"
                                       FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Sub}"
                                       Visibility="{Binding ShowGradeColumn, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="과목" Margin="34,0,0,0" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Sub}"/>
                        </DockPanel>
                        <DockPanel Margin="16,0,4,0" LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right" Text="학년" Width="78" TextAlignment="Center"
                                       FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Sub}"
                                       Visibility="{Binding ShowGradeColumn, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="과목" Margin="34,0,0,0" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Sub}"/>
                        </DockPanel>
                    </UniformGrid>
                </Border>

                <!-- 목록 (두 단 배치 — 왼→오 채우기. 초과 시에만 스크롤) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500" Margin="0,2,0,0">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,3" Margin="4,1" Background="Transparent">
                                    <DockPanel>
                                        <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="4,0,10,0"/>
                                        <ComboBox DockPanel.Dock="Right" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding GradeOptions}" SelectedItem="{Binding Grade}"
                                                  Width="66" VerticalAlignment="Center" Margin="8,0,4,0"
                                                  Visibility="{Binding ShowGrade, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding Subject}" VerticalAlignment="Center" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 두 단 사이 세로 구분선 (헤더~목록 관통) — 헤더 아래 가로선과 같은 톤 -->
                <Border Grid.Row="0" Grid.RowSpan="2" Width="1" HorizontalAlignment="Center"
                        Background="{StaticResource Line}" Margin="0,2,0,2"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
