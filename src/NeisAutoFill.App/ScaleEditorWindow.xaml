<Window x:Class="NeisAutoFill.App.ScaleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="평가척도 설정" Height="480" Width="760" MinWidth="640" MinHeight="380"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 단계 수 -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="단계 수:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox ItemsSource="{Binding LevelCountOptions}" SelectedItem="{Binding LevelCount}"
                      Width="60"/>
        </WrapPanel>

        <TextBlock Grid.Row="1" Margin="0,0,0,6" Foreground="#64748B" FontSize="12" TextWrapping="Wrap"
                   Text="각 단계의 이름을 나이스 드롭다운에 표시되는 그대로 입력하세요 (위 = 최상위 단계). 엑셀 성적표에도 같은 이름을 씁니다. 'AI 서술 뉘앙스'는 서술문 생성 시 등급별 지시문으로 쓰이며 비워도 됩니다."/>

        <!-- 단계 편집 그리드 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Levels}" SelectedItem="{Binding SelectedLevel}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" SelectionMode="Single" GridLinesVisibility="All"
                  RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="단계 이름 (필수 — 나이스·엑셀 공통)" Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                <DataGridTextColumn Header="AI 서술 뉘앙스 (선택)" Binding="{Binding AiNuance, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 버튼 -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="＋ 추가" Command="{Binding AddCommand}" Padding="10,5" Margin="0,0,4,0"/>
                <Button Content="－ 삭제" Command="{Binding RemoveCommand}" Padding="10,5" Margin="0,0,4,0"/>
                <Button Content="▲ 위로" Command="{Binding UpCommand}" Padding="10,5" Margin="0,0,4,0"/>
                <Button Content="▼ 아래로" Command="{Binding DownCommand}" Padding="10,5"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="저장 후 적용" Click="Save_Click" Padding="16,5" Margin="0,0,6,0" FontWeight="Bold"/>
                <Button Content="취소" IsCancel="True" Padding="16,5"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
