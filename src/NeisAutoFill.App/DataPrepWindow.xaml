<Window x:Class="NeisAutoFill.App.DataPrepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="자료 준비" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">

        <!-- 1단계: 평가계획서 -->
        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,4">
                    <Run Text="1단계. 평가계획서" Foreground="#1D4ED8"/>
                    <Run Text=" — 과목별 평가기준과 학생명단" Foreground="#64748B" FontWeight="Normal" FontSize="12"/>
                </TextBlock>
                <WrapPanel Margin="0,4,0,4">
                    <TextBlock Text="처음이라면:" VerticalAlignment="Center" Width="80" Foreground="#475569"/>
                    <Button Content="📄 빈 양식 저장" Command="{Binding SaveStep1TemplateCommand}" Padding="10,5"/>
                    <TextBlock Text="  → 명단·평가기준을 채워서 아래로" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                </WrapPanel>
                <WrapPanel>
                    <TextBlock Text="작성했다면:" VerticalAlignment="Center" Width="80" Foreground="#475569"/>
                    <Button Content="📂 불러오기" Command="{Binding LoadPlanCommand}" Padding="10,5"/>
                    <TextBlock Text="{Binding PlanName}" VerticalAlignment="Center" Margin="8,0,0,0"
                               FontWeight="SemiBold" Foreground="#475569"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- 2단계: 성적입력 양식 -->
        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,4">
                    <Run Text="2단계. 성적입력 양식" Foreground="#1D4ED8"/>
                    <Run Text=" — 학생별 영역 등급과 특기사항을 적을 파일" Foreground="#64748B" FontWeight="Normal" FontSize="12"/>
                </TextBlock>
                <WrapPanel Margin="0,4,0,0">
                    <Button Content="📄 양식 저장" Command="{Binding SaveStep2TemplateCommand}" Padding="10,5"
                            ToolTip="1단계 평가계획서를 불러온 뒤 누르면 과목·영역·명단이 미리 채워집니다"/>
                    <TextBlock Text="  → 과목·영역·학생명단이 미리 채워진 파일이 만들어집니다" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <TextBlock Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="2,0,2,10"
                   Text="성적입력 양식에 등급·특기사항을 채웠다면, 창을 닫고 메인 화면의 [📂 성적파일 열기]로 불러오세요."/>

        <Button Content="완료" IsCancel="True" Padding="24,7" HorizontalAlignment="Right" FontWeight="Bold"/>
    </StackPanel>
</Window>
