<Window x:Class="NeisAutoFill.App.DataPrepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="자료 준비" Width="580" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="자료 준비" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <StackPanel Margin="18,16">
                <!-- 1단계 -->
                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12" Background="{StaticResource Panel2}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="1단계. 평가계획서" FontWeight="Bold" FontSize="14" Foreground="{StaticResource Neis}"/>
                            <Run Text="  과목별 평가기준과 학생명단" Foreground="{StaticResource Sub}" FontSize="12"/>
                        </TextBlock>
                        <WrapPanel Margin="0,4,0,6">
                            <TextBlock Text="처음이라면" VerticalAlignment="Center" Width="76" Foreground="{StaticResource Sub}" FontSize="12"/>
                            <Button Style="{StaticResource AccentGhostButton}" Content="📄 빈 양식 저장" Command="{Binding SaveStep1TemplateCommand}"/>
                            <TextBlock Text="  명단·평가기준을 채워서 아래로" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Text="작성했다면" VerticalAlignment="Center" Width="76" Foreground="{StaticResource Sub}" FontSize="12"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="📂 불러오기" Command="{Binding LoadPlanCommand}"/>
                            <TextBlock Text="{Binding PlanName}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" Foreground="#059669" FontSize="12"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 2단계 -->
                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12" Background="{StaticResource Panel2}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="2단계. 성적입력 양식" FontWeight="Bold" FontSize="14" Foreground="{StaticResource Neis}"/>
                            <Run Text="  학생별 영역 등급과 특기사항을 적을 파일" Foreground="{StaticResource Sub}" FontSize="12"/>
                        </TextBlock>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Style="{StaticResource AccentGhostButton}" Content="📄 양식 저장" Command="{Binding SaveStep2TemplateCommand}"
                                    ToolTip="1단계 평가계획서를 불러온 뒤 누르면 과목·영역·명단이 미리 채워집니다"/>
                            <TextBlock Text="  과목·영역·학생명단이 미리 채워진 파일이 만들어집니다" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <TextBlock Foreground="{StaticResource Sub}" FontSize="12" TextWrapping="Wrap" Margin="2,0,2,12"
                           Text="성적입력 양식에 등급·특기사항을 채웠다면, 창을 닫고 메인 화면의 [📂 성적파일]로 불러오세요."/>

                <Button Style="{StaticResource PrimaryButton}" Content="완료" IsCancel="True" HorizontalAlignment="Right" Padding="28,7"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
