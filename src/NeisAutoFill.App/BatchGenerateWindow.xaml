<Window x:Class="NeisAutoFill.App.BatchGenerateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="전과목 서술문 생성" Height="500" Width="560" MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" DockPanel.Dock="Left" Text="전과목 서술문 생성" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Cancel_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="취소" IsCancel="True" Padding="18,7"/>
                    <Button x:Name="StartButton" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="🚀 생성 시작" Click="Start_Click" Margin="0,0,6,0" Padding="18,7"/>
                </DockPanel>
            </Border>

            <DockPanel Margin="16,12">
                <TextBlock x:Name="DescText" DockPanel.Dock="Top" TextWrapping="Wrap" FontSize="11.5" Foreground="{StaticResource Sub}" Margin="0,0,0,10"
                           Text="생성할 과목을 선택하세요. 생성은 백그라운드로 진행되어 창을 닫거나 다른 작업을 해도 계속됩니다. 이미 생성된 서술문은 새 결과로 덮어써집니다."/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Style="{StaticResource GhostButton}" Content="전체 선택" Click="All_Click" Padding="10,4" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource GhostButton}" Content="전체 해제" Click="None_Click" Padding="10,4"/>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 이상 없는 과목: 한 행에 여러 개(컴팩트) / 문제 과목: 넓게 + 화면 과목 드롭다운 -->
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7"
                                        Padding="10,6" Margin="0,0,6,6" Background="White"
                                        ToolTip="{Binding Summary}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="MinWidth" Value="120"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                    <Setter Property="MinWidth" Value="280"/>
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                    <Setter Property="BorderBrush" Value="#FDBA74"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding IsChecked}" VerticalContentAlignment="Center"
                                                  IsEnabled="{Binding EligibleCount, Converter={StaticResource GreaterThanZero}}">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                                <Setter Property="Foreground" Value="#C0392B"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </CheckBox>
                                        <!-- 화면 과목 매핑 — 이름이 자동으로 안 맞은 과목만 -->
                                        <DockPanel Margin="22,6,0,0" Visibility="{Binding NeedsAttention, Converter={StaticResource BoolToVis}}">
                                            <TextBlock DockPanel.Dock="Left" Text="→ 화면 과목:" FontSize="11" Foreground="#B45309"
                                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox ItemsSource="{Binding ScreenOptions}" SelectedItem="{Binding ScreenSubject}"
                                                      Style="{StaticResource Combo}" FontSize="11.5" MinWidth="130"
                                                      ToolTip="이 과목을 나이스 화면의 어느 과목으로 입력할지 고르세요"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
