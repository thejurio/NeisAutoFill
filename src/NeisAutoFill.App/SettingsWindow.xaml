<Window x:Class="NeisAutoFill.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="설정" Height="620" Width="760" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="설정" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Cancel_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- 하단 버튼 -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="취소" IsCancel="True" Padding="18,7"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="저장 후 적용" Click="Save_Click" Margin="0,0,6,0" Padding="18,7"/>
                </DockPanel>
            </Border>

            <TabControl Margin="10,8" BorderThickness="0" Background="White">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource UnderlineTab}"/>
                </TabControl.ItemContainerStyle>

                <!-- ═══ 일반 ═══ -->
                <TabItem Header="일반">
                    <DockPanel Margin="10,12">
                        <TextBlock DockPanel.Dock="Bottom" Text="{Binding VersionInfo}" FontSize="11"
                                   Foreground="#B8C2CE" Margin="0,0,0,2"/>
                        <StackPanel MaxWidth="640" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <TextBlock Text="나이스 접속" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource Ink}"/>
                            <DockPanel Margin="0,6,0,2">
                                <TextBlock Text="교육청 (지역)" Width="110" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Regions}" SelectedItem="{Binding SelectedRegion}"
                                          DisplayMemberPath="Name" Width="170" HorizontalAlignment="Left"/>
                            </DockPanel>

                            <TextBlock Text="자동클릭 속도" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,18,0,4"/>
                            <TextBlock FontSize="11.5" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Text="'빠름'이 검증된 기본 속도입니다. 나이스 반응이 느린 PC에서 입력이 자주 실패하면 낮춰 보세요."/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="빠름 (기본)" IsChecked="{Binding SpeedFast}" FontSize="12" Margin="0,0,16,0"/>
                                <RadioButton Content="보통" IsChecked="{Binding SpeedNormal}" FontSize="12" Margin="0,0,16,0"/>
                                <RadioButton Content="느림" IsChecked="{Binding SpeedSlow}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </TabItem>

                <!-- ═══ AI 서술문 ═══ -->
                <TabItem Header="AI 서술문">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,12" MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="생성 분량" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="목표 글자 수" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TargetChars, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="자 내외 · 0 = AI 자율" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11.5" Margin="8,0,0,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="최대 영역 수" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxDomains, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="개 · 초과 시 무작위 선정 · 0 = 전체" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11.5" Margin="8,0,0,0"/>
                            </Grid>

                            <TextBlock Text="전체 서술 톤" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,18,0,4"/>
                            <TextBlock FontSize="11.5" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Text="모든 서술문에 공통 적용할 지시문. 비우면 기본 톤(간결한 개조식·객관적 교사 어투)으로 생성됩니다."/>
                            <TextBox Text="{Binding TonePrompt, UpdateSourceTrigger=PropertyChanged}" MinHeight="90" MaxHeight="180"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     Padding="8,6" FontSize="12" VerticalContentAlignment="Top"/>
                            <TextBlock FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"
                                       Text="예: 학생의 노력 과정을 구체적 행동 중심으로 묘사하고, 결과보다 성장에 초점을 둘 것"/>
                            <TextBlock FontSize="11.5" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,10,0,0"
                                       Text="💡 단계별(잘함/보통/노력요함 등) 톤은 [평가 단계] 탭의 'AI 서술 뉘앙스' 칸에서 설정합니다."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ 평가 단계 ═══ -->
                <TabItem Header="평가 단계" DataContext="{Binding Scale}">
                    <Grid Margin="10,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="단계 수" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Sub}" FontSize="12"/>
                            <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding LevelCountOptions}" SelectedItem="{Binding LevelCount}" Width="64"/>
                        </WrapPanel>

                        <TextBlock Grid.Row="1" Margin="0,0,0,8" Foreground="{StaticResource Sub}" FontSize="12" TextWrapping="Wrap"
                                   Text="각 단계의 이름을 나이스 드롭다운에 표시되는 그대로 입력하세요 (위 = 최상위 단계). 엑셀 성적표에도 같은 이름을 씁니다. 'AI 서술 뉘앙스'는 그 단계 학생의 서술문 톤 지시문입니다 (비워도 됨)."/>

                        <DataGrid Grid.Row="2" ItemsSource="{Binding Levels}" SelectedItem="{Binding SelectedLevel}"
                                  Style="{StaticResource CleanGrid}" ColumnHeaderStyle="{StaticResource CleanGridHeader}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" RowHeight="34" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="단계 이름 (나이스·엑셀 공통)" Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                                <DataGridTextColumn Header="AI 서술 뉘앙스 (단계별 톤, 선택)" Binding="{Binding AiNuance, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Style="{StaticResource GhostButton}" Content="＋ 추가" Command="{Binding AddCommand}" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource GhostButton}" Content="－ 삭제" Command="{Binding RemoveCommand}" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource GhostButton}" Content="▲ 위로" Command="{Binding UpCommand}" Margin="0,0,4,0"/>
                            <Button Style="{StaticResource GhostButton}" Content="▼ 아래로" Command="{Binding DownCommand}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>
        </DockPanel>
    </Border>
</Window>
