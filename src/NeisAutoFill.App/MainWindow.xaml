<Window x:Class="NeisAutoFill.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="NEIS 교과평가 자동입력기" Height="740" Width="1070" MinWidth="930" MinHeight="580"
        Icon="app.ico" WindowStyle="None" ResizeMode="CanResize"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver" Closing="Window_Closing"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- 진단 단축키: Ctrl+Shift+V (윈도우 전역 단축키와 겹치지 않음) -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Control+Shift" Key="V" Command="{Binding InspectCommand}"/>
    </Window.InputBindings>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 커스텀 타이틀바 (흰 배경 + 하단 파란 라인) ===== -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="20" Height="20" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="NEIS 교과평가 자동입력기" VerticalAlignment="Center"
                               FontFamily="{StaticResource UiFont}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding VersionText}" VerticalAlignment="Center" Margin="8,1,0,0"
                               FontFamily="{StaticResource UiFont}" FontSize="11" Foreground="#94A3B8"/>

                    <Button DockPanel.Dock="Right" x:Name="BtnClose" Style="{StaticResource CloseButton}"
                            Content="&#xE8BB;" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" x:Name="BtnMax" Style="{StaticResource CaptionButton}"
                            Content="&#xE922;" Click="Max_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button DockPanel.Dock="Right" x:Name="BtnMin" Style="{StaticResource CaptionButton}"
                            Content="&#xE921;" Click="Min_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- ===== 본문 (좌측 컬럼 — 성취기준 패널이 켜져도 이 폭은 유지, 창이 옆으로 늘어난다) ===== -->
            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== 툴바 ===== -->
                <Border Grid.Row="0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                    <DockPanel Margin="14,10">
                        <!-- 오른쪽: 나이스 접속·연결 상태 + 설정 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <!-- 화면 진단 버튼 — 기본 숨김. ❓ 버튼을 Ctrl+Shift+클릭하면 나타남/사라짐 -->
                            <Button Style="{StaticResource GhostButton}" Content="🔎 진단" Command="{Binding InspectCommand}" Margin="0,0,6,0"
                                    Visibility="{Binding ShowDiagButton, Converter={StaticResource BoolToVis}}"
                                    ToolTip="현재 나이스 화면의 클릭 가능한 메뉴·요소를 읽기 전용으로 덤프합니다.&#10;단축키: Ctrl+Shift+V  ·  저장 위치: %AppData%\NeisAutoFill\dom_inspect_*.txt"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="🌐 NEIS 접속" Command="{Binding LaunchEdgeCommand}" Margin="0,0,4,0"
                                    Visibility="{Binding IsConnected, Converter={StaticResource TrueToCollapsed}}"
                                    ToolTip="나이스 전용 브라우저를 엽니다. 로그인 후 [교과별 평가]를 조회하면 자동으로 연결됩니다."/>
                            <Border Background="{StaticResource Panel}" CornerRadius="7" Padding="10,0" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{Binding ConnectionBrush}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ConnectionText}" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Ink}"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource GhostButton}" Content="⚙ 설정" Command="{Binding OpenScaleEditorCommand}" Margin="0,0,4,0"
                                    ToolTip="AI 서술문(글자 수·톤) · 평가 단계 · 교육청 · 자동클릭 속도"/>
                            <Button Style="{StaticResource GhostButton}" Content="❓" Command="{Binding HelpCommand}" Padding="9,7"
                                    PreviewMouseLeftButtonDown="Help_PreviewMouseLeftButtonDown"
                                    ToolTip="사용법 안내 페이지 열기"/>
                        </StackPanel>
                        <!-- 왼쪽 (U6): 작업 흐름 그룹 │ 파일 그룹 -->
                        <StackPanel Orientation="Horizontal">
                            <!-- 전담: 과목 선택 후 [이동] → 그 과목을 가르치는 반들이 탭으로 (반=탭) -->
                            <Border Background="{StaticResource NeisSoft}" CornerRadius="7" Padding="8,3" Margin="0,0,8,0"
                                    Visibility="{Binding IsSubjectMode, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="과목" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Neis}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                    <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding SubjectChoices}" SelectedItem="{Binding PickSubject}" MinWidth="96" Margin="0,0,6,0"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="이동" Command="{Binding GoSubjectCommand}" Padding="12,3"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource GhostButton}" Content="📁 자료 준비" Command="{Binding OpenPlanEditorCommand}" Margin="0,0,6,0"
                                    ToolTip="학생 명단·평가계획을 입력합니다 (평가계획서 파일을 넣으면 AI가 자동 인식)"/>
                            <Button Style="{StaticResource AccentGhostButton}" Content="✨ 교과학습" Command="{Binding OpenGeneratorCommand}"
                                    ToolTip="AI 서술문 생성·나이스 입력 창을 엽니다"/>
                            <Border Width="1" Background="{StaticResource Line}" Margin="10,2,4,2"/>
                            <StackPanel Orientation="Horizontal" Margin="6,0,6,0">
                                <Button Style="{StaticResource GhostButtonLeft}" Content="📂 성적파일" Command="{Binding OpenExcelCommand}" Padding="9,7"/>
                                <Button Style="{StaticResource GhostButtonRight}" Content="▼" Click="Recent_Click" ToolTip="최근 파일"/>
                            </StackPanel>
                            <Button Style="{StaticResource GhostButton}" Content="📤 내보내기" Command="{Binding ExportGradesCommand}"
                                    ToolTip="현재 성적표 전체를 원하는 위치에 엑셀 파일로 내보냅니다"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 연결 안내 배너 (U2) — 미연결이고 안내할 게 있을 때만. 연결되면 사라짐 -->
                <Border Grid.Row="1" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="0,0,0,1" Padding="14,7"
                        Visibility="{Binding ShowConnectionHint, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource AccentGhostButton}" Content="🌐 NEIS 접속"
                                Command="{Binding LaunchEdgeCommand}" Padding="12,3" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionHint}" Foreground="#9A3412" FontSize="12" VerticalAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,0,10,0"/>
                    </DockPanel>
                </Border>

                <!-- 진행 안내 (U1) — 자료 로드 후 '다음 할 일'. 연결 배너가 없을 때만(ShowNextStep 이 반영). 닫기 가능 -->
                <Border Grid.Row="1" Background="{StaticResource NeisSoft}" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,1" Padding="14,7"
                        Visibility="{Binding ShowNextStep, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="✕" Padding="8,2"
                                Command="{Binding DismissNextStepCommand}" ToolTip="이 안내 닫기" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding NextStep}" Foreground="{StaticResource Neis}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>
                    </DockPanel>
                </Border>

                <!-- ===== 과목 탭 + 성적표 (+ U1 빈 화면 시작 안내) ===== -->
                <Grid Grid.Row="2">
                <TabControl ItemsSource="{Binding Subjects}" SelectedItem="{Binding SelectedSubject}"
                            BorderThickness="0" Background="White" Padding="0" Margin="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource UnderlineTab}"/>
                    </TabControl.ItemContainerStyle>
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
                            <TextBlock Text="{Binding TabLabel}"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
                            <DockPanel Margin="14,10,14,0">
                                <!-- U4: 한 줄 — 일괄 입력(좌) + 성취기준·나이스 입력(우). U3: 미연결 시 입력 비활성 -->
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="일괄 입력:" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="12" Margin="0,0,8,0"/>
                                    <ItemsControl DockPanel.Dock="Left" ItemsSource="{Binding DataContext.BulkGradeLabels, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource GhostButton}" Content="{Binding}" Padding="10,5"
                                                        Margin="0,0,4,0" Click="BulkAssign_Click"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button DockPanel.Dock="Left" Style="{StaticResource GhostButton}" Content="지우기" Padding="10,5" Margin="0,0,6,0" Click="BulkClear_Click"/>
                                    <Button DockPanel.Dock="Left" Style="{StaticResource GhostButton}" Content="☑ 전체 선택" Padding="10,5" Click="SelectAllCells_Click"
                                            ToolTip="표의 모든 칸을 선택합니다.&#10;💡 학생 이름을 클릭하면 그 학생 전체, 영역 제목을 클릭하면 그 영역 전체가 선택됩니다 (Ctrl+클릭 = 선택 추가)"/>

                                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="■" Padding="9,5" Command="{Binding CancelCommand}"
                                            ToolTip="진행 중인 나이스 입력을 중지합니다"/>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                                            Content="{Binding DataContext.RunAllLabel, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"
                                            Command="{Binding DataContext.RunAllSubjectsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            IsEnabled="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="여러 대상을 순서대로 나이스에 입력합니다 (각 대상 검증 통과 시 자동 저장).&#10;나이스에 연결된 후 사용할 수 있습니다."/>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource AccentGhostButton}"
                                            Content="{Binding DataContext.RunOneLabel, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"
                                            Command="{Binding RunCommand}"
                                            IsEnabled="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="지금 보는 대상만 나이스에 입력합니다 (저장은 확인 후 직접).&#10;나이스에 연결된 후 사용할 수 있습니다."/>
                                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource GhostToggle}" Content="📖 성취기준" Margin="0,0,10,0"
                                                  IsChecked="{Binding DataContext.ShowCriteriaPanel, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding GridView}" AutoGenerateColumns="True"
                                          Style="{StaticResource CleanGrid}" ColumnHeaderStyle="{StaticResource CleanGridHeader}"
                                          IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          CanUserSortColumns="False" CanUserReorderColumns="False"
                                          SelectionUnit="CellOrRowHeader" SelectionMode="Extended" ClipboardCopyMode="ExcludeHeader"
                                          AutoGeneratingColumn="Grid_AutoGeneratingColumn"
                                          Loaded="GradeGrid_Loaded" PreviewKeyDown="GradeGrid_PreviewKeyDown"
                                          PreviewMouseLeftButtonDown="GradeGrid_PreviewMouseLeftButtonDown"/>
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- U1: 자료가 없을 때 시작 안내 (자료가 로드되면 자동 소멸) -->
                <Border Background="White" Visibility="{Binding Subjects.Count, Converter={StaticResource ZeroToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="760">
                        <TextBlock Text="👋" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="처음이신가요? 세 단계면 준비가 끝납니다" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource Ink}" HorizontalAlignment="Center" Margin="0,0,0,22"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="{StaticResource NeisSoft}" BorderBrush="{StaticResource Neis}" BorderThickness="1.5" CornerRadius="12" Padding="18,16" Width="220">
                                <StackPanel>
                                    <TextBlock Text="STEP 1" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Neis}"/>
                                    <TextBlock Text="📁 자료 준비" FontSize="15.5" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,3,0,4"/>
                                    <TextBlock Text="평가계획서 파일(PDF/HWP)을 넣으면 AI가 자동으로 읽고, 명단은 엑셀에서 붙여넣기 한 번이면 됩니다."
                                               FontSize="12" Foreground="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="시작하기" Command="{Binding OpenPlanEditorCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="→" FontSize="20" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="10,0"/>
                            <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1.5" CornerRadius="12" Padding="18,16" Width="200">
                                <StackPanel>
                                    <TextBlock Text="STEP 2" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                    <TextBlock Text="✅ 성적 입력" FontSize="15.5" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,3,0,4"/>
                                    <TextBlock Text="자동으로 만들어진 성적표에서 드래그와 버튼으로 등급을 한 번에 입력합니다."
                                               FontSize="12" Foreground="{StaticResource Sub}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="→" FontSize="20" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="10,0"/>
                            <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1.5" CornerRadius="12" Padding="18,16" Width="200">
                                <StackPanel>
                                    <TextBlock Text="STEP 3" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                    <TextBlock Text="✨ 서술문 → 나이스" FontSize="15.5" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,3,0,4"/>
                                    <TextBlock Text="AI가 전과목 서술문을 만들고, 등급과 함께 나이스에 자동으로 입력합니다."
                                               FontSize="12" Foreground="{StaticResource Sub}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="이미 만든 엑셀(성적·평가계획서)이 있다면 이 창에 끌어다 놓기만 하면 됩니다" FontSize="12.5"
                                   Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,22,0,4"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center">
                            <Run Text="나이스 입력은 오른쪽 위 "/><Run Text="[🌐 NEIS 접속]" FontWeight="Bold" Foreground="{StaticResource Neis}"/><Run Text=" 버튼으로 전용 브라우저를 열어 로그인·조회하면 자동 연결됩니다."/>
                        </TextBlock>
                        <Button Style="{StaticResource GhostButton}" Content="❓ 자세한 사용법 보기" Command="{Binding HelpCommand}"
                                HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
                </Grid>

                <!-- ===== 상태바 (U2: 마지막 로그 한 줄 + 진행 + 로그 펼치기) ===== -->
                <Border Grid.Row="3" Padding="14,7" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0"
                        ClipToBounds="True">
                    <!-- star 컬럼(로그 한 줄) + Auto 컬럼(진행·토글). 긴 줄은 우측을 밀지 않고 … 로 잘린다 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LastLogLine}" Foreground="{Binding LastLogBrush}" FontSize="12.5"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ProgressBar Width="140" Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                                         Background="{StaticResource Panel}" Foreground="{StaticResource Neis}" BorderThickness="0"
                                         VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <Border Background="{StaticResource NeisSoft}" CornerRadius="7" Padding="10,3" Margin="10,0,0,0"
                                    Visibility="{Binding GenerationStatus, Converter={StaticResource StringToVis}}">
                                <TextBlock Text="{Binding GenerationStatus}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource Neis}" VerticalAlignment="Center"/>
                            </Border>
                            <ToggleButton Style="{StaticResource GhostToggle}" Content="≡ 로그" Padding="10,4" FontSize="12"
                                          IsChecked="{Binding LogExpanded}" Margin="10,0,0,0"
                                          ToolTip="작업 기록 전체를 펼쳐 봅니다. 문의할 때 이 내용을 복사해 주세요."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== 로그 (기본 접힘 — 상태바 [≡ 로그] 로 펼침) ===== -->
                <Border Grid.Row="4" Background="#0F172A" CornerRadius="0" Height="170"
                        Visibility="{Binding LogExpanded, Converter={StaticResource BoolToVis}}">
                    <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                             Background="Transparent" Foreground="#CBD5E1" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" Padding="14,10"
                             VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                             x:Name="LogBox" TextChanged="LogBox_TextChanged"/>
                </Border>
            </Grid>

            <!-- ===== 성취기준 참조 패널 (우측 전체 높이 — 토글 시 창이 옆으로 확장) ===== -->
            <Border Grid.Row="1" Grid.Column="1" Width="300" BorderBrush="{StaticResource Line}" BorderThickness="1,0,0,0"
                    Background="{StaticResource Panel2}"
                    Visibility="{Binding ShowCriteriaPanel, Converter={StaticResource BoolToVis}}">
                <DockPanel Margin="12,10">
                    <TextBlock DockPanel.Dock="Top" Text="이 과목의 성취기준·평가기준" FontWeight="Bold" FontSize="12.5"
                               Foreground="{StaticResource Ink}" Margin="0,0,0,8"/>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding CriteriaPanelStatus}" FontSize="11.5"
                               Foreground="{StaticResource Sub}" TextWrapping="Wrap"
                               Visibility="{Binding CriteriaPanelStatus, Converter={StaticResource StringToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CriteriaPanelItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                            CornerRadius="6" Padding="10,8" Margin="0,0,4,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Domain}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource Neis}"/>
                                            <TextBlock Text="{Binding Achievement}" FontSize="11" Foreground="{StaticResource Sub}"
                                                       TextWrapping="Wrap" Margin="0,2,0,4"
                                                       Visibility="{Binding Achievement, Converter={StaticResource StringToVis}}"/>
                                            <ItemsControl ItemsSource="{Binding Levels}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,2,0,0">
                                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Grade}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Ink}" Width="52" VerticalAlignment="Top"/>
                                                            <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{StaticResource Ink}" TextWrapping="Wrap"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
