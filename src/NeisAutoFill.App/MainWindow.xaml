<Window x:Class="NeisAutoFill.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        Title="NEIS 교과평가 자동입력기" Height="740" Width="1000" MinWidth="820" MinHeight="560"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바: 1줄 = 자료·설정, 2줄 = 나이스 작업 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <DockPanel Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="평가척도:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ActiveScaleSummary}" VerticalAlignment="Center"
                               FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,6,0"/>
                    <Button Content="⚙ 척도 설정" Command="{Binding OpenScaleEditorCommand}" Padding="10,6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="📁 자료 준비" Command="{Binding OpenDataPrepCommand}" Padding="10,6" Margin="0,0,4,0"
                            ToolTip="평가계획서 작성·불러오기와 성적입력 양식 만들기를 한곳에서 진행합니다"/>
                    <TextBlock Text="{Binding PlanName}" VerticalAlignment="Center" Foreground="#64748B" Margin="2,0,14,0"/>
                    <Button Content="📂 성적파일 열기" Command="{Binding OpenExcelCommand}" Padding="10,6" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ExcelName}" VerticalAlignment="Center" Foreground="#64748B" Margin="2,0,0,0"/>
                </StackPanel>
            </DockPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="지역:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding Regions}" SelectedItem="{Binding SelectedRegion}"
                          DisplayMemberPath="Name" MinWidth="130" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="① NEIS 접속" Command="{Binding LaunchEdgeCommand}" Padding="10,6" Margin="0,0,4,0"/>
                <Button Content="② 브라우저 연결" Command="{Binding AttachCommand}" Padding="10,6" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ConnectionText}" Foreground="{Binding ConnectionBrush}"
                           VerticalAlignment="Center" FontWeight="Bold" Margin="4,0,14,0"/>
                <Button Content="✨ AI 서술문 생성기" Command="{Binding OpenGeneratorCommand}" Padding="10,6"/>
            </StackPanel>
        </StackPanel>

        <!-- 과목 탭 -->
        <TabControl Grid.Row="1" ItemsSource="{Binding Subjects}">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
                    <TextBlock Text="{Binding SubjectName}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SubjectViewModel}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                            <Button Content="▶ 입력 시작 (저장은 수동)" Command="{Binding RunCommand}" Padding="8,5" Margin="0,0,6,0"/>
                            <Button Content="■ 중지" Command="{Binding CancelCommand}" Padding="8,5" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding AreasText}" VerticalAlignment="Center" Foreground="#475569"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding GridView}" AutoGenerateColumns="True"
                                  IsReadOnly="True" HeadersVisibility="Column"
                                  CanUserAddRows="False" GridLinesVisibility="All"/>
                    </DockPanel>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- 진행바 -->
        <ProgressBar Grid.Row="2" Height="18" Margin="0,6" Minimum="0"
                     Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"/>

        <!-- 로그 -->
        <TextBox Grid.Row="3" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                 x:Name="LogBox" TextChanged="LogBox_TextChanged"/>
    </Grid>
</Window>
