<Window x:Class="NeisAutoFill.App.MatchPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="입력 전 확인" Height="600" Width="620" MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="입력 전 확인 — 화면과 자료가 완전히 일치하지 않습니다" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Cancel_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="취소" IsCancel="True" Padding="18,7"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="✔ 이대로 입력 시작" Click="Confirm_Click" Margin="0,0,6,0" Padding="18,7"/>
                </DockPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,12">

                    <!-- 과목 불일치 -->
                    <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,12"
                            Visibility="{Binding HasSubjectWarning, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="12.5" Foreground="#92400E" Text="⚠ 과목이 다릅니다"/>
                            <TextBlock Text="{Binding SubjectWarning}" FontSize="12" Foreground="#92400E" TextWrapping="Wrap" Margin="0,4,0,6"/>
                            <CheckBox IsChecked="{Binding SubjectAccepted}" FontSize="12" Foreground="#92400E"
                                      Content="화면 과목이 달라도 이대로 입력하는 것에 동의합니다"/>
                        </StackPanel>
                    </Border>

                    <!-- 학생 확인 -->
                    <StackPanel Visibility="{Binding HasStudentIssues, Converter={StaticResource BoolToVis}}" Margin="0,0,0,14">
                        <TextBlock Text="👤 내 성적표에 없는 학생이 화면에 있어요" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                        <TextBlock Text="이 학생 자리에 누구의 성적을 넣을지 골라 주세요. 넣지 않으려면 '입력 안 함'을 고르면 그 학생은 건너뜁니다."
                                   FontSize="11.5" Foreground="{StaticResource Sub}" Margin="0,3,0,8" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding StudentMaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7" Padding="12,8" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="자리에" FontSize="11.5" Foreground="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <ComboBox Grid.Column="2" Style="{StaticResource Combo}" ItemsSource="{Binding Options}" SelectedItem="{Binding Selected}"/>
                                                <TextBlock Grid.Column="3" Text="의 성적 입력" FontSize="11.5" Foreground="{StaticResource Sub}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding SuggestionNote}" FontSize="11" Foreground="{StaticResource Neis}" Margin="0,4,0,0" HorizontalAlignment="Right"
                                                       Visibility="{Binding SuggestionNote, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 영역 확인 — 화면 순서대로 넣을 영역 고르기 -->
                    <StackPanel Visibility="{Binding HasAreaIssues, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="📋 평가 영역이 화면과 달라요" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                        <TextBlock FontSize="11.5" Foreground="{StaticResource Sub}" Margin="0,3,0,8" TextWrapping="Wrap"
                                   Text="아래는 나이스 화면에 보이는 영역을 위에서부터 순서대로 늘어놓은 것입니다.&#10;각 줄마다 내 성적표의 어떤 영역 성적을 넣을지 골라 주세요. 이름이 같은 영역은 이미 골라져 있습니다.&#10;넣지 않을 줄은 '입력 안 함'을 고르면 건드리지 않고 건너뜁니다."/>
                        <ItemsControl ItemsSource="{Binding OrderMaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7" Padding="12,8" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="줄에는" FontSize="11.5" Foreground="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <ComboBox Grid.Column="2" Style="{StaticResource Combo}" ItemsSource="{Binding Options}" SelectedItem="{Binding Selected}"/>
                                                <TextBlock Grid.Column="3" Text="의 성적 입력" FontSize="11.5" Foreground="{StaticResource Sub}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding SuggestionNote}" FontSize="11" Foreground="{StaticResource Neis}" Margin="0,4,0,0" HorizontalAlignment="Right"
                                                       Visibility="{Binding SuggestionNote, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
