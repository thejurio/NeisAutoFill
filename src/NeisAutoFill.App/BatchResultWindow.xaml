<Window x:Class="NeisAutoFill.App.BatchResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:NeisAutoFill.App.ViewModels"
        Title="전과목 입력 결과" Height="620" Width="660" MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" FontFamily="{StaticResource UiFont}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
        <DockPanel>
            <!-- 타이틀바 -->
            <Border DockPanel.Dock="Top" Height="40" Background="White" BorderBrush="{StaticResource Neis}" BorderThickness="0,0,0,2">
                <DockPanel LastChildFill="False">
                    <Image Source="app.ico" Width="18" Height="18" Margin="12,0,8,0" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="전과목 입력 결과" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Ink}"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- 하단 버튼 -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="11.5" Foreground="{StaticResource Sub}"
                               Text="실패·미도달 과목만 다시 입력합니다. 이미 저장된 과목은 건드리지 않습니다."/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="닫기" Click="Close_Click" Padding="18,7" Margin="6,0,0,0"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="{Binding RetryLabel}" Command="{Binding RetryCommand}"
                            Padding="16,7" Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}"/>
                </DockPanel>
            </Border>

            <!-- 요약 -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="16,10">
                <TextBlock Text="{Binding Summary}" FontWeight="Bold" FontSize="13.5" Foreground="{StaticResource Ink}"/>
            </Border>

            <!-- 과목별 결과 목록 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BatchSubjectRow}">
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10"
                                    Padding="12,10" Margin="0,0,0,8" Background="White">
                                <StackPanel>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Background="{Binding BadgeBg}" CornerRadius="6" Padding="8,2" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Badge}" Foreground="{Binding BadgeFg}" FontSize="11.5" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Subject}" FontWeight="Bold" FontSize="13.5"
                                                   Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource Sub}" FontSize="12"
                                                   VerticalAlignment="Center" TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <!-- 실패 학생 상세 -->
                                    <ItemsControl ItemsSource="{Binding FailedItems}" Margin="0,6,0,0"
                                                  Visibility="{Binding HasFailedItems, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11.5" Foreground="#B45309" TextWrapping="Wrap" Margin="2,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
